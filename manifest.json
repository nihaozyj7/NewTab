{
  "manifest_version": 3,
  "name": "自定义新标签页",
  "version": "1.0.0",
  "description": "一个美观实用的新标签页扩展，带有搜索功能和个性化设置",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icon/icon16.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cn.bing.com/search*",
        "https://www.google.com/search*",
        "https://www.baidu.com/s*",
        "https://www.sogou.com/web*",
        "https://www.so.com/s*",
        "https://yandex.com/search*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
